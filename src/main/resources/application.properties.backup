# ===============================================================================
# CONFIGURACIĂ“N DE LA APLICACIĂ“N DENTVISION SPRING BOOT
# ===============================================================================
# Archivo de configuraciĂłn principal para el sistema de gestiĂłn dental DentVision.
# Contiene todas las propiedades necesarias para el funcionamiento de la aplicaciĂłn
# incluyendo base de datos, seguridad, servidor y serializaciĂłn.
#
# Autor: SENA
# VersiĂłn: 1.0
# Desde: 2024
# ===============================================================================

# ------------------------------
# CONFIGURACIĂ“N GENERAL DE LA APP
# ------------------------------
# Nombre identificador de la aplicaciĂłn Spring Boot
spring.application.name=DentVision_Spring

# ------------------------------
# CONFIGURACIĂ“N DEL SERVIDOR
# ------------------------------
# Puerto en el que se ejecutarĂˇ la aplicaciĂłn (8080 es el puerto por defecto de Spring Boot)
server.port=8080

# ------------------------------
# CONFIGURACIÓN DE BASE DE DATOS MYSQL
# ------------------------------
# URL de conexiĂłn a la base de datos MySQL
# Se utiliza variable de entorno ${URL} para mantener la configuraciĂłn segura
spring.datasource.url=jdbc:mysql://dentvision1.clg6gcmkex9d.us-east-2.rds.amazonaws.com:3306/dentvision

# Usuario de la base de datos
# Se utiliza variable de entorno ${DB_HOST} para mantener la configuraciĂłn segura
spring.datasource.username=admin

# Contraseńa de la base de datos
# Se utiliza variable de entorno ${DB_PASSWORD} para mantener la configuraciĂłn segura
spring.datasource.password=0ll6eWFUV01B3EJLqgP8

# Driver JDBC para MySQL 8.x
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

# ------------------------------
# CONFIGURACIÓN DE JPA / HIBERNATE
# ------------------------------
# Estrategia de DDL (Data Definition Language)
# - update: Actualiza el esquema automĂˇticamente al iniciar la aplicaciĂłn
# - validate: Solo valida el esquema sin hacer cambios
# - create: Crea el esquema desde cero cada vez
# - create-drop: Crea el esquema y lo elimina al finalizar
# - none: No realiza ninguna acciĂłn DDL
spring.jpa.hibernate.ddl-auto=update

# Muestra las sentencias SQL en la consola (Ăştil para debugging)
spring.jpa.show-sql=true

# Formatea las sentencias SQL para mejor legibilidad en consola
spring.jpa.properties.hibernate.format_sql=true

# Dialecto especĂ­fico de MySQL para optimizar las consultas SQL
spring.jpa.database-platform=org.hibernate.dialect.MySQLDialect

# ------------------------------
# CONFIGURACIĂ“N DE JACKSON (JSON)
# ------------------------------
# Habilita la indentaciĂłn en la salida JSON para mejor legibilidad
# Ăštil para desarrollo y debugging de respuestas API
spring.jackson.serialization.indent-output=true